*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when written with `-covermode=count`
*.out

# Dependencies (if vendor is used, keep it; otherwise ignore)
# vendor/

# Environment files
.env
.env.local
.env.*.local

# IDE settings
.vscode/
.idea/
*.swp
*.swo

# OS specific files
.DS_Store
Thumbs.db
